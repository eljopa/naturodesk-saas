/// Batch de synchronisation BDPM.
/// Trace chaque import : date, statut, compteurs, erreurs.
model DrugSyncBatch {
  id             String    @id @default(uuid())
  batchRef       String    @unique  // ex: "2026-03-15" — date de l'import
  source         String    @default("BDPM")
  status         String    @default("PENDING")  // PENDING | RUNNING | DONE | ERROR
  productCount   Int       @default(0)
  substanceCount Int       @default(0)
  newCount       Int       @default(0)    // produits créés
  updatedCount   Int       @default(0)    // produits mis à jour
  inactiveCount  Int       @default(0)    // produits marqués inactifs
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@map("drug_sync_batches")
}

/// Substance active (DCI) extraite de CIS_COMPO_bdpm.
/// Pivot central de normalisation : toute spécialité résout vers une substance.
model DrugSubstance {
  id             String   @id @default(uuid())
  substanceCode  String   @unique  // code substance BDPM (colonne 2 de CIS_COMPO)
  name           String            // DCI officielle BDPM, ex: "PARACETAMOL"
  canonicalName  String            // Forme française affichée, ex: "Paracétamol"
  normalizedKey  String   @unique  // slug pivot, ex: "paracetamol"
  drugClass      String?           // classe pharmacologique (MANUAL ou ATC_DERIVED)
  aliases        String[]          // synonymes DCI connus
  isActive       Boolean  @default(true)
  batchId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Lien optionnel vers KnowledgeTerm(DRUG) pour backward compat Phase C
  knowledgeTermId String?
  knowledgeTerm   KnowledgeTerm? @relation(fields: [knowledgeTermId], references: [id])

  products      DrugProductSubstance[]
  drugAliases   DrugAlias[]
  classMembers  DrugClassMember[]
  intakes       ConsultationMedicationIntake[]
  sideEffects   DrugSideEffect[]
  depletions    DrugNutrientDepletion[]
  analysisItems AnalysisItem[]

  @@index([normalizedKey])
  @@index([isActive])
  @@index([drugClass])
  @@map("drug_substances")
}

/// Spécialité commerciale issue de CIS_bdpm.
model DrugProduct {
  id              String   @id @default(uuid())
  cisCode         String   @unique  // Code CIS BDPM — pivot stable
  name            String            // Dénomination complète, ex: "DOLIPRANE 1000 mg, comprimé"
  normalizedName  String            // slug nom complet, ex: "doliprane-1000-mg-comprime"
  normalizedBrand String?           // slug premier token, ex: "doliprane" — matching rapide
  form            String?           // forme galénique officielle
  route           String?           // voie(s) d'administration
  marketingStatus String?           // Commercialisé | Non commercialisé | Retiré | Suspendu
  ammStatus       String?           // Autorisation active | Retirée | Suspendue
  genericGroupId  String?
  contentHash     String?           // SHA-1 (cisCode|name|form|marketingStatus) — détection changement
  batchId         String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  substances    DrugProductSubstance[]
  drugAliases   DrugAlias[]
  presentations DrugPresentation[]
  genericGroup  DrugGenericGroup?      @relation(fields: [genericGroupId], references: [id])
  intakes       ConsultationMedicationIntake[]

  @@index([normalizedName])
  @@index([normalizedBrand])
  @@index([cisCode])
  @@index([isActive])
  @@map("drug_products")
}

/// Relation spécialité ↔ substance active, avec dosage déclaré.
model DrugProductSubstance {
  id             String @id @default(uuid())
  productId      String
  substanceId    String
  dosageValue    Float?   // ex: 1000
  dosageUnit     String?  // ex: "mg"
  dosageRef      String?  // ex: "par comprimé", "p ml"
  substanceOrder Int      @default(1)

  product   DrugProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  substance DrugSubstance @relation(fields: [substanceId], references: [id])

  @@unique([productId, substanceId])
  @@index([productId])
  @@index([substanceId])
  @@map("drug_product_substances")
}

/// Alias normalisés : noms de marque, abréviations, fautes fréquentes.
/// Clé de résolution rapide (O(1) lookup) dans le pipeline de matching.
model DrugAlias {
  id          String   @id @default(uuid())
  key         String   @unique  // normalizedKey de l'alias
  label       String            // forme lisible originale
  productId   String?           // → spécialité (si alias de marque)
  substanceId String?           // → substance (si alias DCI)
  source      String            // BDPM | MANUAL | SEED
  createdAt   DateTime @default(now())

  product   DrugProduct?   @relation(fields: [productId], references: [id])
  substance DrugSubstance? @relation(fields: [substanceId], references: [id])

  @@index([key])
  @@index([productId])
  @@index([substanceId])
  @@map("drug_aliases")
}

/// Présentation commerciale (conditionnement) issue de CIS_CIP_bdpm.
model DrugPresentation {
  id            String   @id @default(uuid())
  productId     String
  cip7          String?  @unique  // Code CIP7 (7 chiffres)
  cip13         String?  @unique  // Code CIP13 (13 chiffres)
  label         String            // ex: "boîte de 8 comprimés"
  adminStatus   String?           // Présentation active | retirée
  marketStatus  String?           // Commercialisée | Non commercialisée
  batchId       String?
  createdAt     DateTime @default(now())

  product DrugProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("drug_presentations")
}

/// Groupe générique BDPM : originator + génériques associés.
model DrugGenericGroup {
  id          String   @id @default(uuid())
  bdpmGroupId String   @unique  // identifiant numérique du groupe BDPM
  label       String?           // libellé du groupe générique
  createdAt   DateTime @default(now())

  products DrugProduct[]

  @@map("drug_generic_groups")
}

/// Classe pharmacologique — assignée manuellement ou dérivée de l'ATC.
model DrugClass {
  id    String @id @default(uuid())
  code  String @unique  // ex: "ANTICOAGULANT_AVK"
  label String           // ex: "Anticoagulants AVK"
  createdAt DateTime @default(now())

  members DrugClassMember[]

  @@map("drug_classes")
}

/// Appartenance d'une substance à une classe pharmacologique.
model DrugClassMember {
  id          String @id @default(uuid())
  classId     String
  substanceId String
  source      String  // MANUAL | ATC_DERIVED

  class     DrugClass     @relation(fields: [classId], references: [id])
  substance DrugSubstance @relation(fields: [substanceId], references: [id])

  @@unique([classId, substanceId])
  @@index([classId])
  @@index([substanceId])
  @@map("drug_class_members")
}

