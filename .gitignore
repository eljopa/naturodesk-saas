# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dépendances ───────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ───────────────────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Tests & couverture ────────────────────────────────────────────────────────
/coverage
/.nyc_output

# ─── Variables d'environnement (CRITIQUE — ne jamais commiter) ─────────────────
.env*
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test

# ─── Secrets & certificats ─────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
secrets/
.secrets/

# ─── Prisma ────────────────────────────────────────────────────────────────────
# Migrations générées localement (migrations/ doit rester versionné)
prisma/migrations/migration_lock.toml

# ─── Supabase (CLI local) ──────────────────────────────────────────────────────
.supabase/
supabase/.branches/
supabase/.temp/

# ─── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/

# ─── Base de données locale ────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# ─── Éditeurs & OS ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
.idea/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~

# ─── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Déploiement ───────────────────────────────────────────────────────────────
.vercel
.netlify

# ─── Données uploadées / temporaires ───────────────────────────────────────────
/public/uploads/
/tmp/
/temp/

# ─── Rapports & exports ────────────────────────────────────────────────────────
*.pdf
*.csv
*.xlsx
*.xls
